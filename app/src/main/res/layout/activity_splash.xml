<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background">

    <!-- Image de fond (optionnelle) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- Conteneur principal centré -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Logo / Image principale -->
        <ImageView
            android:id="@+id/logo_pizza"
            android:layout_width="411dp"
            android:layout_height="wrap_content"
            android:contentDescription="Logo Pizza"
            android:elevation="4dp"
            android:src="@mipmap/pizza1" />

        <!-- Titre de l'application -->
        <TextView
            android:id="@+id/titre_splash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.05"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="🍕 Pizza Recipes 🍕"
            android:textColor="#164B66"
            android:textSize="30sp"
            android:fontFamily="sans-serif-light"
            android:textStyle="bold|italic" />

        <!-- Sous-titre -->

        <!-- Barre de progression (loading) -->
        <TextView
            android:layout_width="220dp"
            android:layout_height="45dp"
            android:layout_marginTop="8dp"
            android:text="Les meilleures recettes italiennes"
            android:textColor="#054D6A"
            android:textSize="14sp"
            android:textStyle="bold|italic" />

        <ProgressBar
            android:layout_width="78dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:indeterminateTint="#FF9800" />

        <!-- Texte de chargement -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chargement des recettes..."
            android:textColor="#62471D"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>